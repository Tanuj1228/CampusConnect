<%- include('../partials/header') %>

<div class="admin-layout">
    <%- include('../partials/_adminSidebar', { activeMenu: 'reports' }) %>

    <div class="admin-content">
        <div style="display: flex; justify-content: space-between; align-items: flex-end; border-bottom: 2px solid var(--primary); padding-bottom: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem;">
            <div>
                <h1 style="font-size: 2.5rem; font-weight: 800; letter-spacing: -1px; text-transform: uppercase; margin: 0;">Reported Content</h1>
                <p style="color: var(--text-muted); margin-top: 0.5rem; margin-bottom: 0;">Review flagged posts and take appropriate moderation actions.</p>
            </div>
            <div>
                <form action="/admin/reports" method="GET" style="display: flex; gap: 0.5rem; margin: 0;">
                    <select name="status" style="padding: 0.6rem 1rem; border-radius: 6px; border: 1px solid var(--border); background: var(--surface); color: var(--text);" onchange="this.form.submit()">
                        <option value="Pending" <%= filters.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                        <option value="Resolved" <%= filters.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                        <option value="Ignored" <%= filters.status === 'Ignored' ? 'selected' : '' %>>Ignored</option>
                    </select>
                </form>
            </div>
        </div>

        <div class="glass-card">
            <% if (reports.length === 0) { %>
                <p style="text-align: center; color: var(--text-muted); padding: 3rem;">No <%= filters.status.toLowerCase() %> reports found. Great job!</p>
            <% } else { %>
                <div style="overflow-x: auto;">
                    <table style="width: 100%; border-collapse: collapse; text-align: left;">
                        <thead>
                            <tr style="border-bottom: 2px solid var(--border);">
                                <th style="padding: 1rem; font-size: 0.8rem; text-transform: uppercase;">ID</th>
                                <th style="padding: 1rem; font-size: 0.8rem; text-transform: uppercase;">Type</th>
                                <th style="padding: 1rem; font-size: 0.8rem; text-transform: uppercase;">Reporter</th>
                                <th style="padding: 1rem; font-size: 0.8rem; text-transform: uppercase;">Reason</th>
                                <th style="padding: 1rem; font-size: 0.8rem; text-transform: uppercase;">Date</th>
                                <th style="padding: 1rem; font-size: 0.8rem; text-transform: uppercase; text-align: right;">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reports.forEach(r => { %>
                                <tr style="border-bottom: 1px solid var(--border); transition: background 0.2s;">
                                    <td style="padding: 1rem; font-family: monospace; color: var(--text-muted);">#<%= r.id %></td>
                                    <td style="padding: 1rem;">
                                        <span class="badge" style="background: var(--surface); border: 1px solid var(--primary);"><%= r.item_type %></span>
                                    </td>
                                    <td style="padding: 1rem; font-weight: 600;"><%= r.reporter_username %></td>
                                    <td style="padding: 1rem; color: #ef4444; font-weight: 600;"><%= r.reason %></td>
                                    <td style="padding: 1rem; font-size: 0.9rem; color: var(--text-muted);">
                                        <%= new Date(r.created_at).toLocaleDateString() %>
                                    </td>
                                    <td style="padding: 1rem; text-align: right;">
                                        <div style="display: flex; gap: 0.5rem; justify-content: flex-end;">
                                            <% if (r.item_details) { %>
                                                <a href="<%= r.item_details.url %>" target="_blank" class="btn btn-outline" style="padding: 0.25rem 0.5rem; font-size: 0.75rem;">
                                                    <i class="fa-solid fa-eye"></i> View
                                                </a>
                                                <% if (r.item_type === 'Note' && r.item_details.file_url) { %>
                                                    <a href="<%= r.item_details.file_url %>" target="_blank" class="btn btn-outline" style="padding: 0.25rem 0.5rem; font-size: 0.75rem; margin-left: 0.2rem;" title="Download/View File">
                                                        <i class="fa-solid fa-download"></i> File
                                                    </a>
                                                <% } %>
                                            <% } else { %>
                                                <span style="color: var(--text-muted); font-size: 0.85rem; font-style: italic;">Content Deleted</span>
                                            <% } %>

                                            <form action="/admin/reports/<%= r.id %>/status" method="POST" style="margin: 0; display: flex; gap: 0.5rem;">
                                                <select name="status" style="padding: 0.4rem; border-radius: 4px; background: var(--bg); color: var(--text); border: 1px solid var(--border);">
                                                    <option value="Pending" <%= r.status === 'Pending' ? 'selected' : '' %>>Pending</option>
                                                    <option value="Resolved" <%= r.status === 'Resolved' ? 'selected' : '' %>>Resolved</option>
                                                    <option value="Ignored" <%= r.status === 'Ignored' ? 'selected' : '' %>>Ignored</option>
                                                </select>
                                                <input type="text" name="admin_remarks" placeholder="Admin remarks..." value="<%= r.admin_remarks || '' %>" style="padding: 0.4rem; border-radius: 4px; border: 1px solid var(--border); background: var(--surface); color: var(--text);">
                                                <button type="submit" class="btn" style="padding: 0.4rem 0.8rem; font-size: 0.85rem;">Update</button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
