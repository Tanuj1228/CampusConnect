<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Campus Connect</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        const savedTheme = localStorage.getItem('theme') || 'light';
        document.documentElement.setAttribute('data-theme', savedTheme);
    </script>
    <script src="/socket.io/socket.io.js"></script>
</head>

<body>
    <header>
        <a href="/" class="logo">Campus Connect</a>
        <div class="header-right">
            <nav id="main-nav">
                <a href="/">Home</a>
                <a href="/lost-found">Lost & Found</a>
                <a href="/notes">Notes</a>
                <a href="/donations">Donations</a>
                <% if (!user || user.role !== 'admin') { %>
                    <a href="/complaints">Complaints</a>
                <% } %>
                <% if (user) { %>
                    <% if (user.role === 'admin') { %>
                        <a href="/admin/dashboard" style="color: var(--primary); font-weight: 800; border: 1px dashed var(--primary); padding: 0.2rem 0.5rem; border-radius: 4px; display: inline-flex; align-items: center; gap: 0.3rem;"><i class="fa-solid fa-shield-halved"></i> Admin Mod</a>
                    <% } %>
                    <span style="color: var(--text-muted);"><a href="/profile" style="text-decoration: none; font-weight: 600; color: var(--primary);">Hi, <%= user.username %></a></span>
                    <a href="/logout" class="btn btn-outline">Logout</a>
                <% } else { %>
                    <a href="/login">Login</a>
                    <a href="/register" class="btn">Register</a>
                <% } %>
            </nav>

            <div class="header-actions">
                <button onclick="toggleTheme()"
                    style="background:none; border:none; color:var(--text); font-size:1.2rem; cursor:pointer;"
                    title="Toggle Dark/Light Mode">
                    <i id="theme-icon" class="fa-solid fa-moon"></i>
                </button>
                <% if (user) { %>
                    <div style="position: relative; display: inline-block; cursor: pointer;"
                        onclick="toggleNotifications(event)">
                        <i class="fa-solid fa-bell" style="font-size: 1.2rem; color: var(--text);"></i>
                        <span id="notif-badge"
                            style="display: <%= (notifications && notifications.length > 0) ? 'inline-block' : 'none' %>; position: absolute; top: -8px; right: -10px; background: red; color: white; border-radius: 50%; padding: 0.1rem 0.4rem; font-size: 0.7rem; font-weight: bold;">
                            <%= (notifications ? notifications.length : 0) %>
                        </span>

                        <div id="notif-dropdown" class="glass-card"
                            style="display: none; position: absolute; right: 0; top: 30px; width: 320px; padding: 1rem; z-index: 1002; max-height: 400px; overflow-y: auto; text-align: left; cursor: default;"
                            onclick="event.stopPropagation()">
                            <div
                                style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.5rem;">
                                <h4 style="margin: 0; font-size: 1rem;">Notifications</h4>
                                <button onclick="markAllRead()" class="btn btn-outline"
                                    style="padding: 0.2rem 0.5rem; font-size: 0.7rem; display: <%= (notifications && notifications.length > 0) ? 'inline-block' : 'none' %>;"
                                    id="mark-all-read-btn">Mark all read</button>
                            </div>
                            <div id="notif-list">
                                <% if (notifications && notifications.length> 0) { %>
                                    <% notifications.forEach(n=> { %>
                                        <div id="notif-<%= n.id %>"
                                            style="padding: 0.7rem 0.5rem; border-bottom: 1px solid var(--border); font-size: 0.85rem; line-height: 1.4;">
                                            <p style="margin: 0; margin-bottom: 0.4rem;">
                                                <%= n.message %>
                                            </p>
                                            <div
                                                style="display: flex; justify-content: space-between; align-items: center;">
                                                <% if (n.link) { %>
                                                    <a href="<%= n.link %>"
                                                        style="color: var(--primary); text-decoration: none; font-weight: 600;">View
                                                        Details</a>
                                                    <% } else { %>
                                                        <span></span>
                                                        <% } %>
                                                            <button onclick="markRead(<%= n.id %>)"
                                                                style="background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.8rem; padding: 0;"><i
                                                                    class="fa-solid fa-check"></i> Read</button>
                                            </div>
                                        </div>
                                        <% }) %>
                                            <% } else { %>
                                                <p id="no-notif-msg"
                                                    style="color: var(--text-muted); font-size: 0.9rem; text-align: center; margin: 1rem 0;">
                                                    No new notifications</p>
                                                <% } %>
                            </div>
                        </div>
                    </div>
                <% } %>
                <button class="hamburger" onclick="toggleMobileMenu()" aria-label="Toggle Navigation">
                    <i class="fa-solid fa-bars" id="hamburger-icon"></i>
                </button>
            </div>
        </div>
    </header>
    <main>
        <script>
            function toggleTheme() {
                const currentTheme = document.documentElement.getAttribute('data-theme');
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                document.documentElement.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);

                const icon = document.getElementById('theme-icon');
                if (newTheme === 'dark') {
                    icon.classList.replace('fa-moon', 'fa-sun');
                } else {
                    icon.classList.replace('fa-sun', 'fa-moon');
                }
            }

            document.addEventListener('DOMContentLoaded', () => {
                const currentTheme = document.documentElement.getAttribute('data-theme');
                const icon = document.getElementById('theme-icon');
                if (currentTheme === 'dark') {
                    icon.classList.replace('fa-moon', 'fa-sun');
                }
            });

            // Notification Logic
            function toggleNotifications(e) {
                e.stopPropagation();
                const dropdown = document.getElementById('notif-dropdown');
                dropdown.style.display = dropdown.style.display === 'none' ? 'block' : 'none';
            }

            function toggleMobileMenu() {
                const nav = document.getElementById('main-nav');
                const icon = document.getElementById('hamburger-icon');
                nav.classList.toggle('show');
                if (nav.classList.contains('show')) {
                    icon.classList.replace('fa-bars', 'fa-xmark');
                } else {
                    icon.classList.replace('fa-xmark', 'fa-bars');
                }
            }

            document.addEventListener('click', (e) => {
                const dropdown = document.getElementById('notif-dropdown');
                if (dropdown && !e.target.closest('.fa-bell') && !dropdown.contains(e.target)) {
                    dropdown.style.display = 'none';
                }
                
                const nav = document.getElementById('main-nav');
                const icon = document.getElementById('hamburger-icon');
                const hamburgerBtn = e.target.closest('.hamburger');
                if (nav && nav.classList.contains('show') && !nav.contains(e.target) && !hamburgerBtn) {
                    nav.classList.remove('show');
                    icon.classList.replace('fa-xmark', 'fa-bars');
                }
            });

            async function markRead(id) {
                try {
                    await fetch(`/notifications/mark-read/${id}`, { method: 'POST' });
                    document.getElementById(`notif-${id}`).remove();
                    updateBadgeCount(-1);
                } catch (e) { }
            }

            async function markAllRead() {
                try {
                    await fetch('/notifications/mark-all-read', { method: 'POST' });
                    document.getElementById('notif-list').innerHTML = '<p id="no-notif-msg" style="color: var(--text-muted); font-size: 0.9rem; text-align: center; margin: 1rem 0;">No new notifications</p>';
                    document.getElementById('notif-badge').style.display = 'none';
                    document.getElementById('notif-badge').innerText = '0';
                    document.getElementById('mark-all-read-btn').style.display = 'none';
                } catch (e) { }
            }

            function updateBadgeCount(change) {
                const badge = document.getElementById('notif-badge');
                let count = parseInt(badge.innerText || '0');
                count += change;
                if (count <= 0) {
                    badge.style.display = 'none';
                    badge.innerText = '0';
                    document.getElementById('mark-all-read-btn').style.display = 'none';
                    document.getElementById('notif-list').innerHTML = '<p id="no-notif-msg" style="color: var(--text-muted); font-size: 0.9rem; text-align: center; margin: 1rem 0;">No new notifications</p>';
                } else {
                    badge.style.display = 'inline-block';
                    badge.innerText = count;
                }
            }

            // Socket Logic
            var socket = io();
            <% if (user) { %>
                socket.emit('joinUserRoom', <%= user.id %>);
                socket.on('notification', (data) => {
                    // Update Badge
                    updateBadgeCount(1);
                    document.getElementById('mark-all-read-btn').style.display = 'inline-block';

                    const noMsg = document.getElementById('no-notif-msg');
                    if (noMsg) noMsg.remove();

                    // Create Notification Item
                    const div = document.createElement('div');
                    // using a dummy id since it's just received, refreshing will fetch actual ID
                    const tempId = Math.floor(Math.random() * 1000000);
                    div.id = `notif-${tempId}`;
                    div.style = "padding: 0.7rem 0.5rem; border-bottom: 1px solid var(--border); font-size: 0.85rem; line-height: 1.4; background: rgba(37, 99, 235, 0.1);";
                    div.innerHTML = `
                        <p style="margin: 0; margin-bottom: 0.4rem; font-weight: bold;">${data.message}</p>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <a href="#" onclick="location.reload()" style="color: var(--primary); text-decoration: none; font-size: 0.8rem;">Refresh to view</a>
                            <button onclick="markRead(${tempId})" style="background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.8rem; padding: 0;"><i class="fa-solid fa-check"></i> Read</button>
                        </div>
                    `;
                    document.getElementById('notif-list').prepend(div);

                    // Browser Notification/Alert (Optional)
                    // alert("New Notification: " + data.message);
                });
            <% } %>
        </script>