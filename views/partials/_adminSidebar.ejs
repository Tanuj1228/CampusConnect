        </li>
        <li>
            <a href="/admin/reports" style="display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem 1rem; border-radius: 8px; color: var(--text); text-decoration: none; transition: all 0.2s; margin-bottom: 0.2rem;" class="<%= locals.activeMenu === 'reports' ? 'active-nav' : '' %>">
