<style>
    .admin-sidebar a:hover {
        background: var(--bg-hover);
        color: var(--primary);
    }
    .admin-sidebar a.active-nav {
        background: var(--primary);
        color: var(--bg) !important;
        font-weight: 600;
    }
</style>
