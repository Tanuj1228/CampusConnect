<div class="feature-grid" style="grid-template-columns: 1fr; gap: 1.5rem;">
    <% if (complaints.length === 0) { %>
        <p style="color: var(--text-muted);">No complaints found.</p>
    <% } %>
    <% complaints.forEach(complaint => { %>
        <div class="glass-card" style="display: flex; flex-direction: column; gap: 1rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1rem;">
                <div>
                    <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 0.5rem; flex-wrap: wrap;">
                        <h3 style="margin: 0; font-size: 1.25rem;"><%= complaint.title %></h3>
                        <% 
                            let badgeColor = 'var(--text)'; 
                            let badgeBg = 'var(--bg-hover)'; 
                            if (complaint.status === 'Pending') { 
                                badgeColor = '#ca8a04';
                                badgeBg = 'rgba(202, 138, 4, 0.1)'; 
                            } else if (complaint.status === 'In Progress') { 
                                badgeColor = '#2563eb';
                                badgeBg = 'rgba(37, 99, 235, 0.1)'; 
                            } else if (complaint.status === 'Resolved') { 
                                badgeColor = '#16a34a'; 
                                badgeBg = 'rgba(22, 163, 74, 0.1)'; 
                            } else if (complaint.status === 'Rejected') { 
                                badgeColor = '#dc2626';
                                badgeBg = 'rgba(220, 38, 38, 0.1)'; 
                            } 
                        %>
                        <span class="badge" style="background: <%= badgeBg %>; color: <%= badgeColor %>; border: 1px solid <%= badgeColor %>; font-size: 0.8rem;">
                            <%= complaint.status %>
                        </span>
                    </div>
                    <div style="display: flex; gap: 1rem; font-size: 0.85rem; color: var(--text-muted); flex-wrap: wrap;">
                        <span><i class="fa-solid fa-tag"></i> <%= complaint.category %></span>
                        <span><i class="fa-solid fa-flag"></i> Priority: <%= complaint.priority %></span>
                        <span><i class="fa-solid fa-location-dot"></i> <%= complaint.location %></span>
                        <span><i class="fa-solid fa-calendar"></i> <%= new Date(complaint.created_at).toLocaleString() %></span>
                        <% if (complaint.username) { %>
                            <span><i class="fa-solid fa-user"></i> Filed by: @<%= complaint.username %></span>
                        <% } %>
                    </div>
                </div>


            </div>

            <p style="margin: 0.5rem 0; font-size: 0.95rem; line-height: 1.5; color: var(--text);">
                <%= complaint.description %>
            </p>

            <% if (complaint.image_url) { %>
                <div style="margin-bottom: 0.5rem;">
                    <img src="<%= complaint.image_url %>" alt="Complaint Image" style="max-width: 100%; max-height: 200px; border-radius: 8px; border: 1px solid var(--border); object-fit: contain;">
                </div>
            <% } %>

            <% if (complaint.admin_remarks) { %>
                <div style="background: var(--bg-hover); padding: 1rem; border-radius: 8px; border-left: 4px solid var(--primary); margin-top: 0.5rem;">
                    <h4 style="font-size: 0.9rem; margin-bottom: 0.5rem; color: var(--text-muted);">Admin Remarks:</h4>
                    <p style="font-size: 0.95rem; margin: 0; color: var(--text);"><%= complaint.admin_remarks %></p>
                </div>
            <% } %>
        </div>
    <% }) %>
</div>
