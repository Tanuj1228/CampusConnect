<div class="grid">
    <% if (donations.length === 0) { %>
        <p style="color: var(--text-muted); grid-column: 1 / -1;">No items available right now.</p>
    <% } %>
    <% donations.forEach(item => { %>
        <div class="glass-card" style="display: flex; flex-direction: column; height: 100%;">
            <% if (item.donation_type !== 'request') { %>
                <% if (item.image_url) { %>
                    <img src="<%= item.image_url %>" alt="<%= item.title %>" class="item-img">
                <% } else { %>
                    <div class="item-img" style="background: rgba(0,0,0,0.05); display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-weight: 600;">
                        No Image
                    </div>
                <% } %>
            <% } %>

            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem; gap: 0.5rem; flex-wrap: wrap;">
                <h3 style="margin: 0;"><%= item.title %></h3>
                <% 
                    let statusLabel = item.status;
                    let badgeColor = 'var(--text)'; 
                    if (item.status === 'Available') {
                        badgeColor = '#16a34a';
                    } else if (item.status === 'Requested') {
                        badgeColor = '#ea580c';
                        if (item.donation_type === 'request') {
                            statusLabel = 'In Progress';
                        }
                    } else if (item.status === 'Donated') {
                        badgeColor = '#6b7280';
                        statusLabel = 'Completed';
                    }
                %>
                <span class="badge" style="background: var(--bg); color: <%= badgeColor %>; border: 1px solid <%= badgeColor %>;">
                    <%= statusLabel %>
                </span>
            </div>

            <p style="color: var(--text-muted); margin-bottom: 1rem; font-size: 0.9rem;">
                <% if (item.donation_type === 'request') { %>
                    Requested by <strong><%= item.username %></strong>
                <% } else { %>
                    Donated by <strong><%= item.username %></strong>
                <% } %>
            </p>

            <p style="margin-bottom: 1.5rem; font-size: 0.95rem; flex-grow: 1;">
                <%= item.description %>
            </p>

            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                <form action="/admin/donations/<%= item.id %>/delete" method="POST" style="margin: 0; padding-top: 1rem; border-top: 1px solid var(--border); display: flex; justify-content: flex-end;" onsubmit="return confirm('Are you sure you want to completely delete this item?');">
                    <button type="submit" class="btn" style="background: #ef4444; padding: 0.5rem 1rem; font-size: 0.85rem;">Delete Item</button>
                </form>
            <% } else { %>
                <div style="margin-top: auto; border-top: 1px solid var(--border); padding-top: 1rem;">
                    <% if (item.status === 'Available') { %>
                        <div style="background: rgba(0, 0, 0, 0.02); padding: 0.8rem; border-radius: 8px; border: 1px dashed var(--border); margin-bottom: 1rem;">
                            <span style="display: block; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 0.2rem;">
                                <%= item.donation_type === 'request' ? 'Contact to Donate:' : 'Contact to Request:' %>
                            </span>
                            <strong style="word-break: break-all;"><%= item.contact_info %></strong>
                        </div>
                        
                        <% if (user && user.id !== item.user_id) { %>
                            <div style="display: flex; gap: 0.5rem; margin-bottom: 0.5rem;">
                                <button type="button" onclick="openReportModal('Donation', <%= item.id %>)" class="btn btn-outline" style="flex: 1; padding: 0.5rem; color: #ef4444; border-color: #ef4444;" title="Report Spam"><i class="fa-solid fa-flag"></i> Report</button>
                            </div>
                        <% } %>

                        <% if (user && user.id !== item.user_id) { %>
                            <% if (item.donation_type === 'request') { %>
                                <form action="/donations/<%= item.id %>/fulfill" method="POST" style="margin: 0;">
                                    <button class="btn" style="width: 100%; background: #16a34a; border-color: #16a34a; color: white !important;"><i class="fa-solid fa-hand-holding-heart"></i> I want to donate</button>
                                </form>
                            <% } else { %>
                                <form action="/donations/<%= item.id %>/request" method="POST" style="margin: 0;">
                                    <button class="btn" style="width: 100%;"><i class="fa-solid fa-cart-shopping"></i> Request Item</button>
                                </form>
                            <% } %>
                        <% } else if (user && user.id === item.user_id) { %>
                            <button class="btn btn-outline" style="width: 100%;" disabled>Your Post</button>
                        <% } else { %>
                            <a href="/login" class="btn btn-outline" style="width: 100%; display: block; text-align: center;">Log in to Respond</a>
                        <% } %>

                    <% } else if (item.status === 'Requested') { %>
                        <% if (item.donation_type === 'request') { %>
                            <div style="background: rgba(234, 88, 12, 0.05); padding: 0.8rem; border-radius: 8px; border: 1px solid #ea580c; margin-bottom: 1rem; font-size: 0.9rem;">
                                Donor offering help: <strong><%= item.donor_full_name || item.donor_username %></strong>
                            </div>
                            <% if (user && (user.id === item.user_id || user.id === item.donor_id || user.role === 'admin')) { %>
                                <form action="/donations/<%= item.id %>/confirm" method="POST" style="margin: 0;">
                                    <button class="btn" style="width: 100%; background: #ea580c; border-color: #ea580c; color: white !important;"><i class="fa-solid fa-circle-check"></i> Done</button>
                                </form>
                            <% } else { %>
                                <button class="btn" style="background: #ea580c; border-color: #ea580c; color: white !important; width: 100%; cursor: not-allowed;" disabled>In Progress</button>
                            <% } %>
                        <% } else { %>
                            <!-- offer -->
                            <div style="background: rgba(234, 88, 12, 0.05); padding: 0.8rem; border-radius: 8px; border: 1px solid #ea580c; margin-bottom: 1rem; font-size: 0.9rem;">
                                Requested by: <strong><%= item.requester_full_name || item.requester_username %></strong>
                            </div>
                            <% if (user && (user.id === item.user_id || user.id === item.requester_id || user.role === 'admin')) { %>
                                <form action="/donations/<%= item.id %>/confirm" method="POST" style="margin: 0;">
                                    <button class="btn" style="width: 100%; background: #ea580c; border-color: #ea580c; color: white !important;"><i class="fa-solid fa-circle-check"></i> Confirm Handover</button>
                                </form>
                            <% } else { %>
                                <button class="btn" style="background: var(--text-muted); width: 100%; cursor: not-allowed;" disabled>Requested</button>
                            <% } %>
                        <% } %>
                    <% } else { %>
                        <button class="btn" style="background: var(--text-muted); width: 100%; cursor: not-allowed;" disabled>Completed</button>
                    <% } %>
                </div>
            <% } %>
        </div>
    <% }) %>
</div>
