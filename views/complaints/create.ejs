<%- include('../partials/header') %>

<div class="glass-card" style="max-width: 600px; margin: 4rem auto;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h2>Submit Complaint</h2>
        <a href="/complaints" class="btn btn-outline" style="text-decoration: none; padding: 0.5rem 1rem; border: 1px solid var(--border); border-radius: 6px; color: var(--text);">Cancel</a>
    </div>

    <% if (typeof error !== 'undefined' && error) { %>
        <div style="background: rgba(239, 68, 68, 0.2); color: var(--danger); padding: 1rem; border-radius: 8px; margin-bottom: 1rem;">
            <%= error %>
        </div>
    <% } %>

    <form action="/complaints/new" method="POST" enctype="multipart/form-data">
        <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem;">
            <label for="title">Complaint Title</label>
            <input type="text" id="title" name="title" required placeholder="Brief title of the issue...">
        </div>

        <div style="display: flex; gap: 1rem; margin-bottom: 1.5rem;">
            <div style="display: flex; flex-direction: column; gap: 0.5rem; flex: 1;">
                <label for="category">Category</label>
                <select id="category" name="category" required style="padding: 0.8rem; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text);">
                    <option value="" disabled selected>Select Category</option>
                    <option value="WiFi Issue">WiFi Issue</option>
                    <option value="Electricity">Electricity</option>
                    <option value="Hostel">Hostel</option>
                    <option value="Classroom">Classroom</option>
                    <option value="Washroom">Washroom</option>
                    <option value="Library">Library</option>
                    <option value="Canteen">Canteen</option>
                    <option value="Maintenance">Maintenance</option>
                    <option value="Other">Other</option>
                </select>
            </div>

            <div style="display: flex; flex-direction: column; gap: 0.5rem; flex: 1;">
                <label for="priority">Priority Level</label>
                <select id="priority" name="priority" required style="padding: 0.8rem; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text);">
                    <option value="" disabled selected>Select Priority Level</option>
                    <option value="Low">Low</option>
                    <option value="Medium">Medium</option>
                    <option value="High">High</option>
                </select>
            </div>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem;">
            <label for="location">Location</label>
            <input type="text" id="location" name="location" required placeholder="e.g., Room 302, Block A">
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 1.5rem;">
            <label for="description">Detailed Description</label>
            <textarea id="description" name="description" rows="4" required placeholder="Describe the issue in detail..." style="padding: 0.8rem; background: var(--bg); border: 1px solid var(--border); border-radius: 8px; color: var(--text); resize: vertical;"></textarea>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem;">
            <label for="image">Upload Image (Optional)</label>
            <input type="file" id="image" name="image" accept="image/*" style="padding: 0.5rem; background: var(--bg); border-radius: 8px; border: 1px solid var(--border);">
            <span style="font-size: 0.8rem; color: var(--text-muted);">Attach a photo if it helps explain the issue.</span>
        </div>

        <button type="submit" class="btn" style="width: 100%;">Submit Complaint</button>
    </form>
</div>

<%- include('../partials/footer') %>
